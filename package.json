{
  "name": "ocx-slurpyb",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bunx ocx build . --out dist && bun packages/scripts/enrich-index.ts",
    "deploy": "bun run build && wrangler deploy",
    "dev": "bun run build && wrangler dev",
    "enrich": "bun packages/scripts/enrich-index.ts",
    "mcp": "bun packages/mcp/mcp-server.ts",
    "generate": "bun packages/scripts/generate-registry.ts",
    "browse": "bun packages/scripts/browse.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@types/bun": "latest",
    "wrangler": "^4.71.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.3.6"
  }
}
