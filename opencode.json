{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "environment": {
        "CONTEXT7_API_KEY": "{file:~/.secrets/context7-key}"
      },
      "type": "local"
    },
    "ocx-registry": {
      "command": [
        "bun",
        "src/mcp-server.ts"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  }
}
