---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundatons
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
const footerLinks = [
    {
        heading: "Navigation",
        links: [
            { label: "Home", href: "/" },
            { label: "About", href: "/about" },
        ],
    },
    {
        heading: "Socials",
        links: [
            { label: "@yourhandle", href: "https://twitter.com/yourhandle" },
        ],
    },
];
---

<footer class="border-t border-base-100">
    <Wrapper variant="standard" class="py-12 pb-24">
        <div class="xl:grid xl:grid-cols-3 xl:gap-8">
            <div class="text-base-900">
                <a href="/" class="flex items-center text-lg gap-2">
                    <span class="sr-only">Go to homepage</span>
                    <Logo class="h-4 text-base-900" />
                    Your Brand
                </a>
                <p class="mt-1 text-sm text-base-500 text-balance">
                    Your site tagline goes here.
                </p>
            </div>
            <div class="md:grid md:grid-cols-2 md:gap-8 xl:col-span-2">
                {
                    footerLinks.map((section) => (
                        <div class="mt-12 md:mt-0">
                            <h3 class="text-base-900 font-display">
                                {section.heading}
                            </h3>
                            <ul
                                role="list"
                                class="mt-4 text-sm space-y-2 text-base-500"
                            >
                                {section.links.map((link) => (
                                    <li>
                                        <a
                                            title="Button to your page"
                                            aria-label="your label"
                                            href={link.href}
                                            class="hover:text-base-900"
                                        >
                                            {link.label}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </div>
    </Wrapper>
</footer>
