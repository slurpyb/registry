---
interface Props {
  level: "low" | "medium" | "high" | "critical" | "safe" | undefined
  showLabel?: boolean
  class?: string
}

const { level, showLabel = false, class: className = "" } = Astro.props

const config = {
  safe: { color: "bg-green-500", label: "Safe", textColor: "text-green-700" },
  low: { color: "bg-green-500", label: "Low Risk", textColor: "text-green-700" },
  medium: { color: "bg-yellow-500", label: "Medium Risk", textColor: "text-yellow-700" },
  high: { color: "bg-orange-500", label: "High Risk", textColor: "text-orange-700" },
  critical: { color: "bg-red-500", label: "Critical Risk", textColor: "text-red-700" },
}

const cfg = level ? config[level] : null
---

{cfg && (
  <span class:list={["inline-flex items-center gap-1.5", className]}>
    <span class:list={["size-2 rounded-full", cfg.color]} title={cfg.label}></span>
    {showLabel && <span class:list={["text-xs font-medium", cfg.textColor]}>{cfg.label}</span>}
  </span>
)}
