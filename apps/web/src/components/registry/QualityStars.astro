---
interface Props {
  rating: number | undefined
  max?: number
  size?: "sm" | "md"
  class?: string
}

const { rating, max = 5, size = "sm", class: className = "" } = Astro.props

const filled = rating ? Math.min(Math.max(Math.round(rating), 0), max) : 0
const empty = max - filled

const sizeClass = size === "sm" ? "text-xs" : "text-sm"
---

{rating !== undefined && (
  <span class:list={["inline-flex items-center gap-0.5", sizeClass, className]} title={`Quality: ${rating}/${max}`}>
    {Array(filled).fill(null).map(() => (
      <span class="text-yellow-500">★</span>
    ))}
    {Array(empty).fill(null).map(() => (
      <span class="text-base-300">★</span>
    ))}
  </span>
)}
