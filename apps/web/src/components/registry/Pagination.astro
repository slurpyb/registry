---
interface Props {
  current: number
  total: number
  baseUrl: string
}

const { current, total, baseUrl } = Astro.props

// Calculate page range to show
const maxPages = 7
let startPage = Math.max(1, current - Math.floor(maxPages / 2))
let endPage = Math.min(total, startPage + maxPages - 1)

// Adjust if we're near the end
if (endPage - startPage < maxPages - 1) {
  startPage = Math.max(1, endPage - maxPages + 1)
}

const pages = Array.from({ length: endPage - startPage + 1 }, (_, i) => startPage + i)

function pageUrl(page: number): string {
  const url = new URL(baseUrl, "http://localhost")
  if (page > 1) {
    url.searchParams.set("page", String(page))
  } else {
    url.searchParams.delete("page")
  }
  return url.pathname + url.search
}
---

{total > 1 && (
  <nav class="flex items-center justify-center gap-1" aria-label="Pagination">
    {/* Previous */}
    {current > 1 ? (
      <a
        href={pageUrl(current - 1)}
        class="px-3 py-2 text-sm rounded-lg hover:bg-base-100 text-base-600"
        aria-label="Previous page"
      >
        ← Prev
      </a>
    ) : (
      <span class="px-3 py-2 text-sm text-base-400 cursor-not-allowed">← Prev</span>
    )}

    {/* First page + ellipsis */}
    {startPage > 1 && (
      <>
        <a href={pageUrl(1)} class="px-3 py-2 text-sm rounded-lg hover:bg-base-100 text-base-600">
          1
        </a>
        {startPage > 2 && <span class="px-2 text-base-400">...</span>}
      </>
    )}

    {/* Page numbers */}
    {pages.map((page) => (
      <a
        href={pageUrl(page)}
        class:list={[
          "px-3 py-2 text-sm rounded-lg",
          page === current
            ? "bg-base-900 text-white"
            : "hover:bg-base-100 text-base-600",
        ]}
        aria-current={page === current ? "page" : undefined}
      >
        {page}
      </a>
    ))}

    {/* Last page + ellipsis */}
    {endPage < total && (
      <>
        {endPage < total - 1 && <span class="px-2 text-base-400">...</span>}
        <a href={pageUrl(total)} class="px-3 py-2 text-sm rounded-lg hover:bg-base-100 text-base-600">
          {total}
        </a>
      </>
    )}

    {/* Next */}
    {current < total ? (
      <a
        href={pageUrl(current + 1)}
        class="px-3 py-2 text-sm rounded-lg hover:bg-base-100 text-base-600"
        aria-label="Next page"
      >
        Next →
      </a>
    ) : (
      <span class="px-3 py-2 text-sm text-base-400 cursor-not-allowed">Next →</span>
    )}
  </nav>
)}
