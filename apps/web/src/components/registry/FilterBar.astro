---
/**
 * Filter bar for browse page
 * Renders as static HTML - filtering is done client-side via URL params
 */
interface Props {
  domains: string[]
  selectedType?: string
  selectedDomain?: string
  selectedQuality?: string
  selectedRisk?: string
  searchQuery?: string
}

const { 
  domains, 
  selectedType, 
  selectedDomain, 
  selectedQuality, 
  selectedRisk,
  searchQuery 
} = Astro.props

const types = ["skill", "plugin", "agent", "command", "bundle"]
const qualities = ["5", "4", "3", "2", "1"]
const risks = ["low", "medium", "high", "critical"]

// Current URL for preserving other params
const currentUrl = new URL(Astro.request.url)

function buildUrl(param: string, value: string | null): string {
  const url = new URL(currentUrl)
  url.searchParams.delete("page") // Reset to page 1 on filter change
  if (value) {
    url.searchParams.set(param, value)
  } else {
    url.searchParams.delete(param)
  }
  return url.pathname + url.search
}
---

<div class="flex flex-col gap-4 p-4 bg-base-50 rounded-xl border border-base-200">
  <!-- Search -->
  <div>
    <label class="block text-xs font-medium text-base-600 mb-1" for="search">Search</label>
    <form method="get" action="/browse">
      {selectedType && <input type="hidden" name="type" value={selectedType} />}
      {selectedDomain && <input type="hidden" name="domain" value={selectedDomain} />}
      {selectedQuality && <input type="hidden" name="quality" value={selectedQuality} />}
      {selectedRisk && <input type="hidden" name="risk" value={selectedRisk} />}
      <div class="flex gap-2">
        <input
          type="text"
          name="q"
          id="search"
          value={searchQuery || ""}
          placeholder="Search components..."
          class="flex-1 px-3 py-2 text-sm border border-base-300 rounded-lg bg-base-50 text-base-900 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <button type="submit" class="px-4 py-2 text-sm bg-base-900 text-white rounded-lg hover:bg-base-800">
          Search
        </button>
      </div>
    </form>
  </div>

  <!-- Filters -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <!-- Type filter -->
    <div>
      <label class="block text-xs font-medium text-base-600 mb-1">Type</label>
      <select
        class="w-full px-3 py-2 text-sm border border-base-300 rounded-lg bg-base-50 text-base-900"
        onchange={`window.location.href = this.value`}
      >
        <option value={buildUrl("type", null)} selected={!selectedType}>All types</option>
        {types.map((t) => (
          <option value={buildUrl("type", t)} selected={selectedType === t}>
            {t.charAt(0).toUpperCase() + t.slice(1)}
          </option>
        ))}
      </select>
    </div>

    <!-- Domain filter -->
    <div>
      <label class="block text-xs font-medium text-base-600 mb-1">Domain</label>
      <select
        class="w-full px-3 py-2 text-sm border border-base-300 rounded-lg bg-base-50 text-base-900"
        onchange={`window.location.href = this.value`}
      >
        <option value={buildUrl("domain", null)} selected={!selectedDomain}>All domains</option>
        {domains.map((d) => (
          <option value={buildUrl("domain", d)} selected={selectedDomain === d}>
            {d}
          </option>
        ))}
      </select>
    </div>

    <!-- Quality filter -->
    <div>
      <label class="block text-xs font-medium text-base-600 mb-1">Quality</label>
      <select
        class="w-full px-3 py-2 text-sm border border-base-300 rounded-lg bg-base-50 text-base-900"
        onchange={`window.location.href = this.value`}
      >
        <option value={buildUrl("quality", null)} selected={!selectedQuality}>Any quality</option>
        {qualities.map((q) => (
          <option value={buildUrl("quality", q)} selected={selectedQuality === q}>
            {q}+ stars
          </option>
        ))}
      </select>
    </div>

    <!-- Risk filter -->
    <div>
      <label class="block text-xs font-medium text-base-600 mb-1">Risk Level</label>
      <select
        class="w-full px-3 py-2 text-sm border border-base-300 rounded-lg bg-base-50 text-base-900"
        onchange={`window.location.href = this.value`}
      >
        <option value={buildUrl("risk", null)} selected={!selectedRisk}>Any risk</option>
        {risks.map((r) => (
          <option value={buildUrl("risk", r)} selected={selectedRisk === r}>
            {r.charAt(0).toUpperCase() + r.slice(1)}
          </option>
        ))}
      </select>
    </div>
  </div>

  <!-- Clear filters -->
  {(selectedType || selectedDomain || selectedQuality || selectedRisk || searchQuery) && (
    <a
      href="/browse"
      class="text-sm text-blue-600 hover:text-blue-800 hover:underline"
    >
      Clear all filters
    </a>
  )}
</div>
