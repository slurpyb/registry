---
import TypeBadge from "./TypeBadge.astro"
import QualityStars from "./QualityStars.astro"
import SecurityBadge from "./SecurityBadge.astro"

interface Props {
  name: string
  type: "skill" | "plugin" | "agent" | "command" | "bundle" | "profile"
  description: string
  icon?: string
  domain?: string
  subdomain?: string
  quality?: number
  riskLevel?: "low" | "medium" | "high" | "critical"
  tags?: string[]
}

const {
  name,
  type,
  description,
  icon,
  domain,
  subdomain,
  quality,
  riskLevel,
  tags = [],
} = Astro.props

// Truncate description
const maxDesc = 120
const truncatedDesc =
  description.length > maxDesc ? description.slice(0, maxDesc).trim() + "..." : description

// Default icon by type
const defaultIcons: Record<string, string> = {
  skill: "🛠️",
  plugin: "🔌",
  agent: "🤖",
  command: "⚡",
  bundle: "📦",
  profile: "👤",
}
const displayIcon = icon || defaultIcons[type] || "📄"
---

<a
  href={`/components/${name}`}
  class="group block p-4 rounded-xl border border-base-200 bg-base-50 hover:border-base-300 hover:shadow-md transition-all duration-200"
  data-component={name}
>
  <div class="flex items-start gap-3">
    <span class="text-2xl" aria-hidden="true">{displayIcon}</span>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h3 class="font-medium text-base-900 group-hover:text-blue-600 transition-colors truncate">
          {name}
        </h3>
        <TypeBadge type={type} />
        <SecurityBadge level={riskLevel} />
      </div>

      {(domain || subdomain) && (
        <p class="text-xs text-base-500 mt-0.5">
          {domain}{subdomain && ` › ${subdomain}`}
        </p>
      )}

      <p class="text-sm text-base-600 mt-2 line-clamp-2">
        {truncatedDesc}
      </p>

      <div class="flex items-center justify-between mt-3">
        <div class="flex items-center gap-2">
          <QualityStars rating={quality} />
          {tags.length > 0 && (
            <span class="text-xs text-base-400">
              {tags.slice(0, 3).join(" • ")}
            </span>
          )}
        </div>
        <button
          type="button"
          class="add-to-cart text-xs px-3 py-1 rounded-full bg-base-100 text-base-600 hover:bg-base-900 hover:text-white transition-colors"
          data-name={name}
          data-type={type}
          data-description={description}
          data-icon={icon}
          onclick="event.preventDefault(); event.stopPropagation(); window.addToCart && window.addToCart(this.dataset)"
        >
          + Add
        </button>
      </div>
    </div>
  </div>
</a>
