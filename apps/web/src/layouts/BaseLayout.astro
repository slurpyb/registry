---
// foundations
// Foundations
import "@/styles/global.css";
import BaseHead from "@/components/foundations/head/BaseHead.astro";
// Sections
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/Navigation.astro";
// Scripts
// Hides nav and footer on selected screens by passing
// the hideNav and hideFooter props
// <BaseLayout hideNav={true} hideFooter={true}>

// Accept SEO props to pass to BaseHead
interface Props {
    hideNav?: boolean;
    hideFooter?: boolean;
    seo?: {
        title?: string;
        description?: string;
        canonical?: string;
        ogImage?: string;
        ogImageAlt?: string;
        article?: {
            publishedTime?: string;
            modifiedTime?: string;
            author?: string;
            tags?: string[];
        };
        jsonLd?: object | object[];
    };
}

const { hideNav = false, hideFooter = false, seo } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead seo={seo} />
    </head>
    <body class="relative flex flex-col bg-base-50 text-base-900 min-h-svh">
        {!hideNav && <Navigation />}
        <main class="grow pt-24 md:pt-28">
            <slot />
        </main>
        {!hideFooter && <Footer />}
    </body>
</html>
