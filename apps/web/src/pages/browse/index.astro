---
import { getCollection } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Wrapper from "@/components/foundations/containers/Wrapper.astro"
import { RegistryBrowser } from "@/components/react/RegistryBrowser"

// Get all components
const allComponents = await getCollection("components")

// Convert to plain objects for React
const components = allComponents.map((c) => ({
  name: c.data.name,
  type: c.data.type,
  description: c.data.description,
  domain: c.data.domain,
  subdomain: c.data.subdomain,
  quality: c.data.quality,
  riskLevel: c.data.riskLevel,
  tags: c.data.tags || [],
  icon: c.data.icon,
  author: c.data.author,
  capabilities: c.data.capabilities || [],
  safeToPublish: c.data.safeToPublish,
}))

// Get initial filter params from URL
const url = new URL(Astro.request.url)
const initialFilters = {
  type: url.searchParams.get("type") || undefined,
  domain: url.searchParams.get("domain") || undefined,
  quality: url.searchParams.get("quality") ? parseInt(url.searchParams.get("quality")!) : undefined,
  risk: url.searchParams.get("risk") || undefined,
  q: url.searchParams.get("q") || undefined,
}

// SEO
const seo = {
  title: "Browse Components — OCX Registry",
  description: `Browse ${allComponents.length} AI components: skills, plugins, agents, commands, and bundles.`,
}
---

<BaseLayout seo={seo}>
  <Wrapper class="py-8">
    <RegistryBrowser 
      client:only="react"
      components={components} 
      initialFilters={initialFilters} 
    />
  </Wrapper>
</BaseLayout>
