---
import { getCollection } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Wrapper from "@/components/foundations/containers/Wrapper.astro"
import { BundleGallery } from "@/components/react/BundleGallery"

// Get all bundles
const bundles = await getCollection("bundles")
const bundleData = bundles.map((bundle) => ({
  name: bundle.data.name,
  description: bundle.data.description,
  dependencies: bundle.data.dependencies,
}))

// SEO
const seo = {
  title: "Bundles — OCX Registry",
  description: `Browse ${bundles.length} curated component bundles for common workflows.`,
}
---

<BaseLayout seo={seo}>
  <Wrapper class="py-8">
    <BundleGallery client:only="react" bundles={bundleData} />
  </Wrapper>
</BaseLayout>
